# =============================================================================
# AI Triage Nurse — Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Then run:  python setup.py   (stamps values into K8s manifests, Dockerfile, CI)
# =============================================================================

# ---- Required: Your GitHub org or username (for container registry) ---------
GITHUB_ORG=YOUR_ORG

# ---- Required: Azure resource group containing the AKS cluster --------------
AZURE_RESOURCE_GROUP=YOUR_RESOURCE_GROUP

# ---- Optional: Foundry Local model overrides --------------------------------
FOUNDRY_MODEL_CHAT=phi-4-mini
FOUNDRY_MODEL_AUDIO=whisper-tiny

# ---- Optional: Foundry Local API endpoint -----------------------------------
# The app connects to Foundry Local's OpenAI-compatible API.
# For local dev: http://localhost:5273/v1 (default when running `foundry service start`)
# For K8s: point to the Foundry Local DaemonSet service or host network
FOUNDRY_API_BASE=http://localhost:5273/v1
FOUNDRY_API_KEY=foundry-local

# ---- Optional: App settings -------------------------------------------------
APP_PORT=8080
LOG_LEVEL=info

# ---- Optional: Kubernetes namespace -----------------------------------------
K8S_NAMESPACE=ai-triage-nurse

# ---- Optional: Flux git branch to watch -------------------------------------
FLUX_BRANCH=main
